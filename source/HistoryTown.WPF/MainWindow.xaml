<Window x:Class="HistoryTown.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История Города - Лабораторная 4" Height="500" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button x:Name="BtnLoad" Content="Загрузить карту" Click="BtnLoad_Click" Padding="10,5"/>
            <TextBlock x:Name="TxtStatus" Text="Карта не загружена" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Начальное здание (A):" Margin="0,5"/>
                <ComboBox x:Name="ComboStart" DisplayMemberPath="Name"/>

                <TextBlock Text="Конечное здание (B):" Margin="0,10,0,5"/>
                <ComboBox x:Name="ComboEnd" DisplayMemberPath="Name"/>

                <Separator Margin="0,15"/>

                <Button x:Name="BtnBfs" Content="Обход BFS" Click="BtnBfs_Click" Margin="0,5" IsEnabled="False"/>
                <Button x:Name="BtnDfs" Content="Обход DFS" Click="BtnDfs_Click" Margin="0,5" IsEnabled="False"/>
                <Button x:Name="BtnCheckReach" Content="Проверить достижимость (A -> B)" Click="BtnCheckReach_Click" Margin="0,5" IsEnabled="False"/>
                <Button x:Name="BtnComponents" Content="Компоненты связности" Click="BtnComponents_Click" Margin="0,5" IsEnabled="False"/>
            </StackPanel>

            <TextBox x:Name="TxtResult" Grid.Column="1" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas"/>
        </Grid>

        <TextBlock Grid.Row="2" Text="Лабораторная работа №4 - Вариант 12 (Исторический город)" Foreground="Gray" Margin="0,10,0,0"/>
    </Grid>
</Window>
